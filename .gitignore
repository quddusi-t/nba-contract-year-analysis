# real data stays local — only the synthetic sample is committed
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep

# generated on demand by src/make_mock_upload.py — never committed
data/mock/

# secrets for the web console — never commit (password + GitHub token)
.streamlit/secrets.toml

# python
.venv/
__pycache__/
*.pyc
*.egg-info/
.ipynb_checkpoints/

# stata
stata/output/
*.log
*.ster

.DS_Store
